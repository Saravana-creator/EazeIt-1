# ─── Environment ────────────────────────────────────────────
NODE_ENV=production

# ─── MongoDB ────────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# ─── Server ─────────────────────────────────────────────────
PORT=5000

# ─── JWT ────────────────────────────────────────────────────
# Use a strong random secret in production (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_strong_secret_here

# ─── Admin Credentials ──────────────────────────────────────
# These are the static admin credentials used for the admin login
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStrongAdminPassword

# ─── CORS / Frontend Origins ────────────────────────────────
# Comma-separated list of allowed frontend URLs
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ─── Razorpay ───────────────────────────────────────────────
# Get your API keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
